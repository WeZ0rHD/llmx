    "patterns": [
      "sk-[A-Za-z0-9-_]{16,}",
      "sk_live_[A-Za-z0-9]{16,}",
      "sk_test_[A-Za-z0-9]{16,}",
      "ghp_[A-Za-z0-9]{16,}",
      "gho_[A-Za-z0-9]{16,}",
      "xox[baprs]-[A-Za-z0-9-]{10,}",
      "AIza[0-9A-Za-z_-]{16,}",
      "AKIA[0-9A-Z]{16}",
